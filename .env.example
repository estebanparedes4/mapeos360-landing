# Copia este archivo a .env.local y completa con tus valores

# URL del sitio (en producción será tu dominio)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google Analytics (opcional)
# NEXT_PUBLIC_GA_ID=G_XXXXXXX

# Email para formulario (opcional, si usas un servicio backend)
# NEXT_PUBLIC_FORM_ENDPOINT=https://api.tudominio.com/contact

# Integración con Formspree (opcional)
# NEXT_PUBLIC_FORMSPREE_ID=f_XXXXX

# SendGrid (si envías emails desde backend)
# SENDGRID_API_KEY=SG.XXXXX
